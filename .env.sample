# Required configuration (no in-code defaults are used)
MC_HOST=127.0.0.1
MC_PORT=25565
MC_USERNAME=Marvin

# Dialogue module - required
QUOTE_ENABLED=true
QUOTE_URL=https://raw.githubusercontent.com/Xe/douglas-adams-quotes/main/quotes.json
QUOTE_INTERVAL_MS=15000
QUOTE_PROBABILITY=1
QUOTE_MAX_LEN=200
QUOTE_CACHE_FILE=dialogue/cache.json
QUOTE_RADIUS=32

# Logging
LOG_DIR=logs
LOG_LEVEL=info
