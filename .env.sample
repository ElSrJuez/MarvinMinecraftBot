# Minecraft Marvin Bot Configuration

# Server connection
MC_HOST=127.0.0.1
MC_PORT=25565
MC_USERNAME=Marvin

# Dialogue module configuration
# Set QUOTE_ENABLED=false to disable the dialogue module
QUOTE_ENABLED=true
# Comma-separated URL(s) to JSON quote lists (strings or objects with a `quote` field)
QUOTE_URL=https://raw.githubusercontent.com/Xe/douglas-adams-quotes/main/quotes.json
# Dialogue seed file (local quotes to merge with remote URLs)
QUOTE_SEED_FILE=modules/dialogue/quotes.json
# Interval between quote attempts (milliseconds)
QUOTE_INTERVAL_MS=15000
# Probability [0..1] to actually send a quote at each interval
QUOTE_PROBABILITY=1
# Maximum length of each chat message chunk
QUOTE_MAX_LEN=200
# Where to store fetched/cached quotes (relative to project)
QUOTE_CACHE_FILE=state/dialogue_cache.json
# Radius (blocks) within which players must be present for quotes to appear
QUOTE_RADIUS=16

# Lock orchestrator
LOCK_CONFIG_FILE=modules/locks/locks.json
LOCK_STATE_FILE=state/locks.json

# Memory module (file-backed JSONL storage for skills)
MEMORY_DIR=state
MEMORY_MAX_ENTRIES=100

# LazySleeper skill
SLEEPER_ENABLED=true
SLEEPER_BED_SEARCH_RADIUS=32
SLEEPER_CHAT_ENABLED=true
SLEEPER_RETRY_COOLDOWN_MS=20000

# Outpost skill
OUTPOST_ENABLED=true
OUTPOST_COMMAND=Marvin, stay here
OUTPOST_RETURN_INTERVAL_MS=30000
OUTPOST_RETURN_RADIUS=5
OUTPOST_CHAT_ENABLED=true

# Narrator skill
# Set NARRATOR_ENABLED=true to enable narrator observations and LLM commentary
NARRATOR_ENABLED=false
# Whether to send narrator LLM commentary to chat
NARRATOR_CHAT_ENABLED=true
# Observation radius in blocks (events/polls beyond this are ignored)
NARRATOR_OBSERVE_RADIUS=32
# Interval between polling snapshots (milliseconds) - how often to snapshot world state
NARRATOR_POLL_INTERVAL_MS=3000
# Interval between LLM narration attempts (milliseconds) - how often to call the LLM
NARRATOR_LLM_INTERVAL_MS=30000
# Maximum observations to buffer before clearing (after narration)
NARRATOR_MAX_OBSERVATIONS=50
# LLM provider: openai, anthropic, google, etc.
NARRATOR_LLM_PROVIDER=openai
# Model identifier (e.g. gpt-4o-mini, claude-3-haiku, gemini-1.5-flash)
NARRATOR_LLM_MODEL=gpt-4o-mini
# API key for the LLM provider
NARRATOR_LLM_API_KEY=
# LLM sampling temperature (0.0-1.0)
NARRATOR_LLM_TEMPERATURE=0.7
# Maximum tokens for LLM response
NARRATOR_LLM_MAX_TOKENS=100
# Path to narrator prompt artifacts file (system prompts, templates, fragments)
NARRATOR_PROMPTS_FILE=modules/skills/narrator/prompts.json

# Logging configuration
LOG_DIR=logs
LOG_LEVEL=debug
