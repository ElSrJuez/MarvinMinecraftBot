{
  "_doc": "Polling sink: state read on an interval and diffed against previous snapshot. Each entry defines a field to read, how to extract it, and what constitutes a meaningful change worth recording. ALL observation text lives here — no hardcoded strings in code.",

  "sources": [
    {
      "id": "nearestPlayer",
      "read": "bot.nearestEntity(e => e.type === 'player' && e !== bot.entity)",
      "fields": {
        "present": {
          "extract": "entity !== null",
          "diff": "boolean",
          "observations": {
            "true→false": "{player} walked away. Alone again.",
            "false→true": "{player} showed up."
          },
          "stateTemplate": { "true": "{player} is here.", "false": "Nobody around." }
        },
        "distance": {
          "extract": "entity.position.distanceTo(bot.entity.position)",
          "diff": "threshold",
          "threshold": 5,
          "observations": {
            "decreased": "{player} is getting closer.",
            "increased": "{player} is moving away."
          },
          "note": "Only meaningful when present=true. Threshold avoids jitter noise."
        },
        "heldItem": {
          "extract": "entity.heldItem?.name ?? 'empty'",
          "diff": "string",
          "observation": "{player} switched to {value}.",
          "stateTemplate": "{player} is holding {value}."
        },
        "sneaking": {
          "extract": "entity.crouching ?? false",
          "diff": "boolean",
          "observations": {
            "false→true": "{player} started sneaking.",
            "true→false": "{player} stopped sneaking."
          },
          "stateTemplate": { "true": "{player} is sneaking." }
        }
      },
      "note": "Primary observation target. All fields gated on entity != null."
    },
    {
      "id": "playerCount",
      "read": "Object.values(bot.players).filter(p => p.entity && p.entity !== bot.entity).length",
      "diff": "number",
      "observations": {
        "0": "Nobody around.",
        "increased": "More people nearby now.",
        "decreased": "Someone left."
      }
    },
    {
      "id": "timeOfDay",
      "read": "bot.time.timeOfDay",
      "diff": "bands",
      "bands": {
        "dawn":      [0, 2000],
        "morning":   [2000, 6000],
        "midday":    [6000, 9000],
        "afternoon": [9000, 12000],
        "dusk":      [12000, 13500],
        "night":     [13500, 22500],
        "lateNight": [22500, 24000]
      },
      "observation": "It's {band} now.",
      "stateTemplate": "It's {band}."
    },
    {
      "id": "weather",
      "fields": {
        "raining": {
          "read": "bot.isRaining",
          "diff": "boolean",
          "observations": {
            "false→true": "It started raining.",
            "true→false": "Rain stopped."
          },
          "stateTemplate": { "true": "It's raining." }
        },
        "thundering": {
          "read": "bot.thunderState > 0.5",
          "diff": "boolean",
          "observations": {
            "false→true": "Thunder rolling in.",
            "true→false": "Thunder subsided."
          },
          "stateTemplate": { "true": "Thunder overhead." }
        }
      }
    },
    {
      "id": "nearbyMobs",
      "read": "Object.values(bot.entities).filter(e => e.type === 'mob' && e.position.distanceTo(bot.entity.position) < radius)",
      "diff": "countByName",
      "observations": {
        "appeared": "{count} {name}(s) nearby.",
        "disappeared": "No more {name}(s)."
      },
      "note": "Grouped count by mob name. Diff detects new mob types appearing or disappearing."
    },
    {
      "id": "botHealth",
      "read": "bot.health",
      "diff": "threshold",
      "threshold": 2,
      "observations": {
        "decreased": "Something hurt me. How delightful.",
        "low": "Health dangerously low. Not that I care."
      },
      "stateTemplate": "Health at {value}."
    },
    {
      "id": "loneliness",
      "read": "derived",
      "derivedFrom": "nearestPlayer.present",
      "diff": "duration",
      "durationThresholds": [60000],
      "observations": {
        "60000": "I've been alone for {minutes} minutes. Not that anyone's counting."
      },
      "note": "Single threshold. Marvin goes for maximum overkill regardless."
    }
  ]
}
